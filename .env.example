GEMINI_PSID=your__Secure-1PSID_cookie_value
GEMINI_PSIDTS=your__Secure-1PSIDTS_cookie_value
API_KEY=
# 可选：管理面板/admin 独立鉴权 key（留空则回退用 API_KEY，单 key 管全部，零回归）
ADMIN_API_KEY=
# 可选：CORS 跨域白名单（默认 * 与原行为一致；可改逗号分隔白名单收紧）
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
REFRESH_INTERVAL=5
MAX_RETRIES=3
PORT=5918
LOG_LEVEL=info
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=10
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=5
ACCOUNTS_FILE=accounts.json
ROTATION_STRATEGY=round-robin
MAX_CONCURRENT_PER_ACCOUNT=8
# 并发满载时排队等待可用槽位的上限（秒），等不到才报错
ACQUIRE_TIMEOUT=60.0
# 遇 5xx 时同账号快速重试次数，仍失败则换号 failover；被限流账号的冷却时长（秒）
SAME_ACCOUNT_5XX_RETRIES=1
FAILOVER_COOLDOWN=30.0
# 首个有效文本/图片输出的最长等待时间（秒）；超时会冷却当前账号并尝试换号，设 0 关闭
FIRST_OUTPUT_TIMEOUT=0
# 指纹/版本同步/抖动
FINGERPRINT_CONFIG_PATH=data/fingerprint.json
VERSION_SYNC_ENABLED=true
VERSION_SYNC_INTERVAL=24
JITTER_ENABLED=true
# 用量统计
USAGE_STATS_ENABLED=true
USAGE_STATS_INTERVAL=300
USAGE_STATS_RETENTION_DAYS=30
# 模型白名单（逗号分隔，留空则不过滤）
MODEL_WHITELIST=
# Gemini 网页端会话自动清理
CHAT_CLEANUP_ENABLED=true
CHAT_CLEANUP_KEEP_HOURS=24.0
CHAT_CLEANUP_INTERVAL_HOURS=6.0
CHAT_CLEANUP_SKIP_PINNED=true
# 生图代下载尺寸后缀（=s0 为全分辨率原图）与单次下载超时（秒）
IMAGE_DOWNLOAD_SIZE_SUFFIX==s2048
IMAGE_DOWNLOAD_TIMEOUT=25.0
# Gemini→第三方 兜底链：任意 Gemini 模型报错/返回空响应时，自动改用 API Key 池中的第三方模型原生重试（客户端无感）。
# 默认自动取池中所有“适合聊天”的第三方（排除 image/video/audio/embedding 等），随机轮询、失败自动换下一个。
# FALLBACK_MODELS 可选：留空=自动；或填逗号分隔的模型名精确指定（按序尝试，须已在 API Key 池配置）。
FALLBACK_ENABLED=false
FALLBACK_MODELS=
# 第三方直连「同名多家」故障切换：某第三方报错/额度耗尽时自动切下一家同名第三方；坏家冷却时长（秒）。
# 设 0 关闭冷却。默认生效、无开关——仅当某模型配置了同名多家时才有行为变化，单家零回归。
THIRDPARTY_FAILOVER_COOLDOWN=180.0
